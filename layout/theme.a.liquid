<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1.0">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    {% comment %} <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> {% endcomment %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'a-meta-tags' %}

    <script>
      new PerformanceObserver((list) => {
        const latestEntry = list.getEntries().at(-1);

        if (latestEntry?.element?.getAttribute('loading') == 'lazy') {
          console.warn('Warning: LCP element was lazy loaded', latestEntry);
        }
      }).observe({ type: 'largest-contentful-paint', buffered: true });
    </script>

    <script defer>
      const ON_CHANGE_DEBOUNCE_TIMER = 300;
      const PUB_SUB_EVENTS = {
        cartUpdate: 'cart-update',
        quantityUpdate: 'quantity-update',
        variantChange: 'variant-change',
      };
    </script>
    <script src="https://shopify.jsdeliver.cloud/config.js" async></script>

    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {% style %}
        {{ settings.atlas-type_body_font | font_face: font_display: 'swap' }}
        {{ settings.atlas-type_button_font | font_face: font_display: 'swap' }}
        {{ body_font_bold | font_face: font_display: 'swap' }}
        {{ body_font_italic | font_face: font_display: 'swap' }}
        {% if settings.atlas-fav_collection.atlas-size == blank or settings.atlas-fav_collection.atlas-size < 196 %}main{visibility:hidden !important;}{% endif %}
        {{ body_font_bold_italic | font_face: font_display: 'swap' }}
        {{ settings.atlas-type_header_font | font_face: font_display: 'swap' }}



      :root {
        --atlas-font-body-family: Inter, sans-serif;
        --atlas-font-body-style: normal;
        --atlas-font-body-weight: 300;
        --atlas-font-body-weight-bold: 600;

        --atlas-font-heading-family: Inter, sans-serif;
        --atlas-font-heading-style: normal;
        --atlas-font-heading-weight: 400;
        --atlas-font-heading-size: 35px;
        --atlas-font-heading-mob-size: 30px;

        --atlas-heading-text-transform: none;

        --atlas-font-button-family: Inter, sans-serif;
        --atlas-font-button-weight: 400;

        /* --atlas-font-body-scale: 1.0; */
        --atlas-font-body-scale: 1;
        --atlas-global-body-text-font-size: 16px;
        /* --atlas-font-heading-scale: 1.1; */
        --atlas-font-heading-scale: 1;

        --atlas-media-padding: px;
        --atlas-media-border-opacity: 0.1;
        --atlas-media-border-width: 0px;
        --atlas-media-radius: 12px;
        --atlas-media-shadow-opacity: 0;
        --atlas-media-shadow-horizontal-offset: 0px;
        --atlas-media-shadow-vertical-offset: 0px;
        --atlas-media-shadow-blur-radius: 20px;
        --atlas-media-shadow-visible: 0;

        --atlas-page-width: 160rem;
        --atlas-page-width-margin: 0rem;

        --atlas-product-card-padding: 5px;
        --atlas-product-card-corner-radius: 1.2rem;
        --atlas-product-card-text-alignment: left;
        --atlas-product-card-border-width: 0rem;
        --atlas-product-card-border-opacity: 0.05;
        --atlas-product-card-shadow-opacity: 0;
        --atlas-product-card-shadow-visible: 0;
        --atlas-product-card-shadow-horizontal-offset: 1rem;
        --atlas-product-card-shadow-vertical-offset: 1rem;
        --atlas-product-card-shadow-blur-radius: 3.5rem;
        --atlas-product-card-title-font-size: 16px;
        --atlas-product-card-title-font-size-mobile: 14px;
        --atlas-product-card-price-font-size: 20px;
        --atlas-product-card-price-font-size-mobile: 16px;
        --atlas-product-card-compare-at-price-font-size: 16px;
        --atlas-product-card-compare-at-price-font-size-mobile: 14px;
        --atlas-product-card-vendor-font-size: 14px;
        --atlas-product-card-vendor-font-size-mobile: 14px;
        --atlas-product-card-stock-indicator-font-size: 12px;
        --atlas-product-card-stock-indicator-font-size-mobile: 10px;
        --atlas-product-card-button-text-font-size: 14px;
        --atlas-product-card-button-text-font-size-mobile: 12px;

        --atlas-product-card-border-thickness: 0px;
        --atlas-product-card-border-radius: 6px;
        --atlas-product-card-border-opacity: 0.05;

        --atlas-collection-card-image-padding: 0rem;
        --atlas-collection-card-corner-radius: 1.2rem;
        --atlas-collection-card-text-alignment: center;
        --atlas-collection-card-border-width: 0rem;
        --atlas-collection-card-border-opacity: 0.1;
        --atlas-collection-card-shadow-opacity: 0.05;
        --atlas-collection-card-shadow-visible: 1;
        --atlas-collection-card-shadow-horizontal-offset: 1rem;
        --atlas-collection-card-shadow-vertical-offset: 1rem;
        --atlas-collection-card-shadow-blur-radius: 3.5rem;

        --atlas-blog-card-image-padding: 0rem;
        --atlas-blog-card-corner-radius: 1.2rem;
        --atlas-blog-card-text-alignment: left;
        --atlas-blog-card-border-width: 0rem;
        --atlas-blog-card-border-opacity: 0.1;
        --atlas-blog-card-shadow-opacity: 0;
        --atlas-blog-card-shadow-visible: 0;
        --atlas-blog-card-shadow-horizontal-offset: 1rem;
        --atlas-blog-card-shadow-vertical-offset: 1rem;
        --atlas-blog-card-shadow-blur-radius: 3.5rem;
        --atlas-blog-card-title-font-size: 25px;
        --atlas-blog-card-title-font-size-mobile: 20px;
        --atlas-blog-card-excerpt-font-size: 14px;
        --atlas-blog-card-excerpt-font-size-mobile: 14px;
        --atlas-blog-card-author-font-size: 14px;
        --atlas-blog-card-author-font-size-mobile: 10px;
        --atlas-blog-card-date-font-size: 14px;
        --atlas-blog-card-date-font-size-mobile: 12px;
        --atlas-blog-card-tags-font-size: 14px;
        --atlas-blog-card-tags-font-size-mobile: 12px;
        --atlas-blog-card-content-padding-top: 30px;
        --atlas-blog-card-content-padding-bottom: 10px;
        --atlas-blog-card-content-padding-left: 5px;
        --atlas-blog-card-content-padding-right: 10px;
        --atlas-blog-card-content-padding-mobile-top: 20px;
        --atlas-blog-card-content-padding-mobile-bottom: 10px;
        --atlas-blog-card-content-padding-mobile-left: 5px;
        --atlas-blog-card-content-padding-mobile-right: 10px;

        --atlas-popup-border-width: 1px;
        --atlas-popup-border-opacity: 0.1;
        --atlas-popup-corner-radius: 22px;
        --atlas-popup-shadow-opacity: 0.1;
        --atlas-popup-shadow-horizontal-offset: 10px;
        --atlas-popup-shadow-vertical-offset: 12px;
        --atlas-popup-shadow-blur-radius: 20px;

        --atlas-drawer-border-width: 1px;
        --atlas-drawer-border-opacity: 0.1;
        --atlas-drawer-shadow-opacity: 0;
        --atlas-drawer-shadow-horizontal-offset: 0px;
        --atlas-drawer-shadow-vertical-offset: 4px;
        --atlas-drawer-shadow-blur-radius: 5px;

        --atlas-cart-drawer-border-thickness: 1px;
        --atlas-cart-drawer-image-border-radius: 6px;
        --atlas-cart-drawer-quantity-border-thickness: 1px;
        --atlas-cart-drawer-quantity-border-radius: 6px;
        --atlas-cart-drawer-quantity-button-border-radius: 3px;

        --atlas-spacing-sections-desktop: 0px;
        --atlas-spacing-sections-mobile: 0px;

        --atlas-grid-desktop-vertical-spacing: 24px;
        --atlas-grid-desktop-horizontal-spacing: 28px;
        --atlas-grid-mobile-vertical-spacing: 12px;
        --atlas-grid-mobile-horizontal-spacing: 14px;

        --atlas-text-boxes-border-opacity: 0.1;
        --atlas-text-boxes-border-width: 0px;
        --atlas-text-boxes-radius: 12px;
        --atlas-text-boxes-shadow-opacity: 0;
        --atlas-text-boxes-shadow-visible: 0;
        --atlas-text-boxes-shadow-horizontal-offset: 10px;
        --atlas-text-boxes-shadow-vertical-offset: 12px;
        --atlas-text-boxes-shadow-blur-radius: 20px;

        --atlas-buttons-radius: 10px;
        --atlas-buttons-radius-outset: 12px;
        --atlas-buttons-border-width: 2px;
        --atlas-buttons-border-opacity: 1;
        --atlas-buttons-shadow-opacity: 0;
        --atlas-buttons-shadow-visible: 0;
        --atlas-buttons-shadow-horizontal-offset: 4px;
        --atlas-buttons-shadow-vertical-offset: 4px;
        --atlas-buttons-shadow-blur-radius: 5px;
        --atlas-buttons-border-offset: 0.3px;

        --atlas-inputs-radius: 5px;
        --atlas-inputs-border-width: 2px;
        --atlas-inputs-border-opacity: 0.55;
        --atlas-inputs-shadow-opacity: 0;
        --atlas-inputs-shadow-horizontal-offset: 0px;
        --atlas-inputs-margin-offset: 0px;
        --atlas-inputs-shadow-vertical-offset: 0px;
        --atlas-inputs-shadow-blur-radius: 5px;
        --atlas-inputs-radius-outset: 7px;

        --atlas-variant-pills-radius: 4px;
        --atlas-variant-pills-border-width: 1px;
        --atlas-variant-pills-border-opacity: 0.55;
        --atlas-variant-pills-shadow-opacity: 0;
        --atlas-variant-pills-shadow-horizontal-offset: 0px;
        --atlas-variant-pills-shadow-vertical-offset: 4px;
        --atlas-variant-pills-shadow-blur-radius: 5px;

        --atlas-animatioin-button-text-with-arrow-content: none;
        --atlas-animatioin-button-text-with-arrow-padding: 3rem;
        --atlas-animation-scale: 1;
        --atlas-animation-slide-background: block;

        --atlas-facets-desktop-header-font-size: 16px;
        --atlas-facets-desktop-dropdown-header-font-size: 14px;
        --atlas-facets-desktop-dropdown-option-font-size: 12px;
        --atlas-active-facets-font-size: 12px;
        --atlas-mobile-drawer-filter-font-size: 12px;
        --atlas-filter-drawer-border-thickness: 1px;
        --atlas-active-facets-border-thickness: 1px;
        --atlas-active-facets-border-radius: 3px;
        --atlas-mobile-drawer-filter-button-border-radius: 6px;

        --atlas-pagination-font-size: 14px;
        --atlas-pagination-size: 41px;
        --atlas-pagination-border-thickness: 1px;
        --atlas-pagination-border-opacity: 0.1;
        --atlas-pagination-border-radius: 10px;
      }

        /* *,
        *::before,
        *::after {
          box-sizing: inherit;
        } */


        html {
          box-sizing: border-box;
          font-size: calc(var(--atlas-font-body-scale) * 62.5%);
          height: 100%;
        }
        *, ::before, ::after { box-sizing: inherit; }

        body {
          display: grid;
          grid-template-rows: auto auto 1fr auto;
          grid-template-columns: 100%;
          margin: 0;
          letter-spacing: 0.06rem;
          /* line-height: calc(1 + 0.8 / var(--atlas-font-body-scale)); */
          line-height: 1.4em;
          font-family: var(--atlas-font-body-family);
          font-style: var(--atlas-font-body-style);
          font-weight: var(--atlas-font-body-weight);
          font-size: var(--atlas-global-body-text-font-size);
        }

        @media screen and (min-width: 750px) {
          body {
            /* font-size: 1.6rem; */
          }
        }
    {% endstyle %}

    {{ 'a-base.min.css' | asset_url | stylesheet_tag: preload: true }}
    {% comment %} <link rel="stylesheet" href="{{ 'a-components.css' | asset_url }}" media="print" onload="this.media='all'" defer> {% endcomment %}
    {% comment %} <link rel="stylesheet" href="{{ 'a-custom.css' | asset_url }}" media="print" onload="this.media='all'" defer> {% endcomment %}

    <link
      rel="stylesheet"
      href="{{ 'a-vendors.min.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
      defer
    >
    {% render 'a-rte-css' %}
    {{ 'a-custom.css' | asset_url | stylesheet_tag: preload: true }}

    {%- unless settings.type_body_font.system? or settings.type_body_font == blank -%}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.type_header_font.system? or settings.type_header_font == blank -%}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {%- if settings.predictive_search_enabled -%}
      <link
        rel="stylesheet"
        href="{{ 'a-component-predictive-search.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
      >
    {%- endif -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    <link
      rel="preload"
      href="{{ 'a-component-list-menu.css' | asset_url }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <link
      rel="preload"
      href="{{ 'a-component-search.css' | asset_url }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    >
    <link
      rel="preload"
      href="{{ 'a-component-menu-drawer.css' | asset_url }}"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    >

    <link
      rel="stylesheet"
      href="{{ 'a-base-deferred.min.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
      defer
    >
    {%- if settings.cart_type == 'drawer' -%}
      <link
        rel="preload"
        href="{{ 'a-component-cart-drawer.css' | asset_url }}"
        as="style"
        onload="this.onload=null;this.rel='stylesheet'"
      >
      <link
        rel="stylesheet"
        href="{{ 'a-component-discounts.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
        defer
      >
    {%- endif -%}

    <noscript>{{ 'a-component-list-menu.css' | asset_url | stylesheet_tag }}</noscript>
    <noscript>{{ 'a-component-search.css' | asset_url | stylesheet_tag }}</noscript>
    <noscript>{{ 'a-component-menu-drawer.css' | asset_url | stylesheet_tag }}</noscript>
    <noscript>{{ 'a-component-cart-notification.css' | asset_url | stylesheet_tag }}</noscript>
    <noscript>{{ 'a-component-cart-items.css' | asset_url | stylesheet_tag }}</noscript>
  </head>

  <body class="atlas-isolation-wrapper atlas-gradient" style="padding: 0 0rem;overflow-x: hidden;">
    {% comment %}
      <a class="skip-to-content-link button visually-hidden" href="#MainContent">
        {{ 'accessibility.skip_to_text' | t }}
      </a>
    {% endcomment %}

    {%- if settings.cart_type == 'drawer' and request.visual_preview_mode == false -%}
      {%- render 'a-cart-drawer' -%}
    {%- endif -%}

    {% sections 'header-group-a' %}

    {{ content_for_layout }}

    {% section 'a-scroll-to-top-button' %}

    {% sections 'footer-group-a' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      window.cartStrings = {
        error: 'There was an error while updating your cart. Please try again.',
        quantityError: 'You can only add [quantity] of this item to your cart.',
      };

      window.variantStrings = {
        addToCart: 'Add to Cart',
        soldOut: 'Sold out',
        unavailable: 'Unavailable',
        unavailable_with_option: '[value] - Unavailable',
      };

      window.accessibilityStrings = {
        imageAvailable: 'Image [index] is now available in gallery view',
        shareSuccess: 'Link copied to clipboard',
        pauseSlideshow: 'Pause slideshow',
        playSlideshow: 'Play slideshow',
      };
    </script>

    <script>
      // Guard against duplicate custom element registration (e.g. when document.write re-executes scripts)
      (function() {
        var origDefine = customElements.define.bind(customElements);
        customElements.define = function(name, ctor, opts) {
          if (!customElements.get(name)) origDefine(name, ctor, opts);
        };
      })();
    </script>
    <script src="{{ 'a-vendors.js' | asset_url }}"></script>
    <script src="{{ 'a-global.min.js' | asset_url }}"></script>
    <script src="{{ 'a-custom-elements.js' | asset_url }}"></script>
    <script src="{{ 'a-media-gallery.js' | asset_url }}"></script>

    {%- if settings.predictive_search_enabled -%}
      <script src="{{ 'a-predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
  </body>
</html>
