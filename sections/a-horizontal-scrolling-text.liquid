{%- liquid
  assign section_id_variable = section.id
-%}

{% if request.visual_preview_mode %}
  {% comment %} For rendering in the theme editor visual preview. {% endcomment %}
  {% assign section_id_variable = 'id' %}
{% endif %}

{%- style -%}
  .atlas-isolation-wrapper .horizontal-scrolling-text-{{ section_id_variable }} {
    overflow: hidden;
    white-space: nowrap;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    position: relative;
  }

  .atlas-isolation-wrapper .horizontal-scrolling-text__wrapper-{{ section_id_variable }} {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    width: 100%;
  }

  .atlas-isolation-wrapper .horizontal-scrolling-text__container-{{ section_id_variable }} {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: scroll-left linear infinite;
    animation-duration: {{ 60 | divided_by: section.settings.speed }}s;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .atlas-isolation-wrapper .horizontal-scrolling-text__item-{{ section_id_variable }} {
    display: inline-block;
    padding: 0 {{ section.settings.text_spacing }}rem;
    font-size: {{ section.settings.text_size }}px;
    color: {{ section.settings.text_color }};
  }

  .atlas-isolation-wrapper .horizontal-scrolling-text__item-{{ section_id_variable }} strong,
  .atlas-isolation-wrapper .horizontal-scrolling-text__item-{{ section_id_variable }} b {
    color: {{ section.settings.highlighted_text_color }};
  }

  .atlas-isolation-wrapper .horizontal-scrolling-text__loop_container-{{ section_id_variable }} {
    width: fit-content;
  }
{%- endstyle -%}

{%- capture loop_content -%}
  {%- for block in section.blocks -%}
    <div class="horizontal-scrolling-text__item-{{ section_id_variable }} block-{{ block.id }}">
      {{- block.settings.title -}}
    </div>
  {%- endfor -%}
{%- endcapture -%}

<div
  class="horizontal-scrolling-text horizontal-scrolling-text-{{ section_id_variable }}"
  style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
>
  <div class="horizontal-scrolling-text__wrapper-{{ section_id_variable }}">
    <div class="horizontal-scrolling-text__container-{{ section_id_variable }}">
      {%- for i in (1..6) -%}
        <div class="horizontal-scrolling-text__loop_container-{{ section_id_variable }}">
          {{- loop_content -}}
        </div>
      {%- endfor -%}
    </div>
  </div>
  <div class="fade-in__left_container"></div>
  <div class="fade-in__right_container"></div>
</div>

{%- schema -%}
{
  "name": "Horizontal sliding text",
  "class": "atlas-isolation-wrapper atlas-gradient",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 0.5,
      "max": 10,
      "default": 1,
      "step": 0.5
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Text spacing",
      "min": 1,
      "max": 5,
      "default": 3,
      "step": 0.5
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "highlighted_text_color",
      "label": "Bolded text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color_background",
      "id": "section_background_gradient",
      "label": "Section background gradient",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)",
      "visible_if": "{{ section.settings.use_gradient_background }}"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_gradient_background == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Desktop bottom padding",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "title",
          "default": "Atlas",
          "label": "Text"
        }
      ]
    }
  ]
}
{%- endschema -%}
