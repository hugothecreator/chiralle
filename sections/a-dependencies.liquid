{%- comment -%} Core JS files {%- endcomment -%}
<script>
  /* Guard: prevent customElements.define from throwing on duplicate names
     AND block host theme from registering elements that Atlas needs its own version of.

     Host themes (Dawn, Horizon, etc.) register elements like media-gallery,
     slider-component, header-drawer, product-form, etc. Atlas also defines
     some of these. Without a guard, the first duplicate throws NotSupportedError
     and crashes the entire script.

     For most elements, whoever registers first wins (host theme's version is fine).
     But media-gallery and slider-component MUST use Atlas's classes because
     Atlas's HTML structure and JS (atlas-media-gallery.js) depend on Atlas-specific
     methods (setActiveMedia, resetPages, isSlideVisible, etc.).

     Execution order:
       1. This inline script (immediate)
       2. Host theme deferred scripts from <head>  → __atlas_scripts_phase = false
       3. atlas-init-flag.js (first atlas deferred) → sets __atlas_scripts_phase = true
       4. atlas-vendors.js, atlas-global.min.js, atlas-custom-elements.js, atlas-media-gallery.js
  */
  if (!window.__atlas_ce_guard) {
    window.__atlas_ce_guard = true;
    var _origDefine = customElements.define.bind(customElements);
    var _atlasOnly = { 'media-gallery': true, 'slider-component': true, 'product-form': true };

    customElements.define = function (name, ctor, opts) {
      if (_atlasOnly[name] && !window.__atlas_scripts_phase) return;
      if (customElements.get(name)) return;
      return _origDefine(name, ctor, opts);
    };
  }

  if (typeof ON_CHANGE_DEBOUNCE_TIMER === 'undefined') {
    window.ON_CHANGE_DEBOUNCE_TIMER = 300;
  }
  if (typeof PUB_SUB_EVENTS === 'undefined') {
    window.PUB_SUB_EVENTS = {
      cartUpdate: 'cart-update',
      quantityUpdate: 'quantity-update',
      variantChange: 'variant-change',
    };
  }
</script>
