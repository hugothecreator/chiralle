  /* Neutralize host theme .section CSS grid (Horizon, etc.) on atlas section wrappers */
  .atlas-isolation-wrapper.section {
    display: block;
    grid-template-columns: unset;
    min-height: auto;
  }

  .atlas-isolation-wrapper *,
  .atlas-isolation-wrapper *::before,
  .atlas-isolation-wrapper *::after {
    box-sizing: border-box;
  }

  .atlas-isolation-wrapper {
    letter-spacing: 0.6px;
    line-height: 1.4em;
    font-family: var(--atlas-font-body-family);
    font-style: var(--atlas-font-body-style);
    font-weight: var(--atlas-font-body-weight);
    font-size: var(--atlas-global-body-text-font-size);
  }

  .atlas-isolation-wrapper p,
  .atlas-isolation-wrapper span {
    font-family: var(--atlas-font-body-family);
  }

  /* Base styles for custom elements that host themes may not style */
  .atlas-isolation-wrapper modal-opener {
    display: block;
    width: 100%;
    height: 100%;
  }

  .atlas-isolation-wrapper .product {
    margin: 0;
  }

  /* Critical grid/layout rules — inline to prevent host theme CSS conflicts on .grid/.page-width */
  .atlas-isolation-wrapper .page-width {
    max-width: var(--atlas-page-width);
    margin: 0 auto;
    padding: 0 20px;
  }
  .atlas-isolation-wrapper .grid {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    margin-bottom: 20px;
    padding: 0;
    list-style: none;
    column-gap: var(--atlas-grid-mobile-horizontal-spacing);
    row-gap: var(--atlas-grid-mobile-vertical-spacing);
  }
  .atlas-isolation-wrapper .grid:last-child {
    margin-bottom: 0;
  }
  .atlas-isolation-wrapper .grid__item {
    width: calc(25% - var(--atlas-grid-mobile-horizontal-spacing) * 3 / 4);
    max-width: calc(50% - var(--atlas-grid-mobile-horizontal-spacing) / 2);
    flex-grow: 1;
    flex-shrink: 0;
  }
  .atlas-isolation-wrapper .grid--1-col .grid__item {
    max-width: 100%;
    width: 100%;
  }
  .atlas-isolation-wrapper .grid--2-col .grid__item {
    width: calc(50% - var(--atlas-grid-mobile-horizontal-spacing) / 2);
  }
  @media screen and (min-width: 750px) {
    .atlas-isolation-wrapper .page-width {
      padding: 0 50px;
    }
    .atlas-isolation-wrapper .grid {
      column-gap: var(--atlas-grid-desktop-horizontal-spacing);
      row-gap: var(--atlas-grid-desktop-vertical-spacing);
    }
    .atlas-isolation-wrapper .grid__item {
      width: calc(25% - var(--atlas-grid-desktop-horizontal-spacing) * 3 / 4);
      max-width: calc(50% - var(--atlas-grid-desktop-horizontal-spacing) / 2);
    }
    .atlas-isolation-wrapper .grid--2-col .grid__item {
      width: calc(50% - var(--atlas-grid-desktop-horizontal-spacing) / 2);
    }
    .atlas-isolation-wrapper .grid--2-col-tablet .grid__item {
      width: calc(50% - var(--atlas-grid-desktop-horizontal-spacing) / 2);
    }
    .atlas-isolation-wrapper .grid--3-col .grid__item {
      width: calc(33.33% - var(--atlas-grid-desktop-horizontal-spacing) * 2 / 3);
    }
  }
{%- endstyle -%}

