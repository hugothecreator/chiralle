{%- comment -%} Global JS variables (with guards to avoid overwriting host theme) {%- endcomment -%}
<script>
  if (typeof window.shopUrl === 'undefined') {
    window.shopUrl = '{{ request.origin }}';
  }
  if (typeof window.routes === 'undefined') {
    window.routes = {
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      cart_url: '{{ routes.cart_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}',
    };
  }
  if (typeof window.cartStrings === 'undefined') {
    window.cartStrings = {
      error: 'There was an error while updating your cart. Please try again.',
      quantityError: 'You can only add [quantity] of this item to your cart.',
    };
  }
  if (typeof window.variantStrings === 'undefined') {
    window.variantStrings = {
      addToCart: 'Add to Cart',
      soldOut: 'Sold out',
      unavailable: 'Unavailable',
      unavailable_with_option: '[value] - Unavailable',
    };
  }
  if (typeof window.accessibilityStrings === 'undefined') {
    window.accessibilityStrings = {
      imageAvailable: 'Image [index] is now available in gallery view',
      shareSuccess: 'Link copied to clipboard',
      pauseSlideshow: 'Pause slideshow',
      playSlideshow: 'Play slideshow',
    };
  }
</script>

