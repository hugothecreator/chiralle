{% comment %} {{ 'a-section-image-comparison-slider.css' | asset_url | stylesheet_tag }} {% endcomment %}
<style>
  {% comment %} CSS for the image comparison slider.css file {% endcomment %}
  .atlas-isolation-wrapper .split-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    position: relative;
  }

  .atlas-isolation-wrapper .split-container--full {
    grid-template-columns: 1fr;
  }

  .atlas-isolation-wrapper .split-container--reversed {
    direction: rtl;
  }

  .atlas-isolation-wrapper .split-container--reversed > * {
    direction: ltr;
  }

  @media screen and (max-width: 900px) {
    .atlas-isolation-wrapper .split-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .atlas-isolation-wrapper .text-block {
    max-width: 600px;
    margin: 0 auto;
  }

  .atlas-isolation-wrapper .image-compare {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    height: 100%;
  }

  .atlas-isolation-wrapper .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .atlas-isolation-wrapper .section__image_comparison_slider .image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .atlas-isolation-wrapper .section__image_comparison_slider .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .atlas-isolation-wrapper .image--before {
    z-index: 2;
  }

  .atlas-isolation-wrapper .image--after {
    z-index: 1;
  }

  .atlas-isolation-wrapper .divider {
    position: absolute;
    top: 0;
    left: 50%;
    height: 100%;
    width: 4px;
    transform: translateX(-50%);
    z-index: 3;
    cursor: ew-resize;
  }

  .atlas-isolation-wrapper .divider__icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .atlas-isolation-wrapper .slider-control {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: ew-resize;
    margin: 0;
    z-index: 4;
  }
</style>
{%- liquid
  assign global_heading_size = settings.enable_global_heading_font_size
  assign global_body_size = settings.enable_global_body_font_size
  assign global_color = settings.enable_global_color
  assign section_id_variable = section.id
-%}

{% if request.visual_preview_mode %}
  {% comment %} For rendering in the theme editor visual preview. {% endcomment %}
  {% assign section_id_variable = 'id' %}
  {% assign section_id_selector = '' %}
{% else %}
  {% assign section_id_variable = section.id %}
  {% assign section_id_selector = '#image-slider-section{{ section.id }}' %}
{% endif %}

<style>
  {%- if request.visual_preview_mode -%}
    {% comment %} don't want fade-in animation in preview mode because it messes up preview {% endcomment %}
    .animation_section,
    .animation_section > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto !important;
    }
  {%- endif -%}

  /* Section Container Styles */
  .atlas-isolation-wrapper {{ section_id_selector }} .section__image_comparison_slider {
    padding: 5px 0;
  }

  .atlas-isolation-wrapper {{ section_id_selector }} .section-container-{{ section_id_variable }} {
    padding-top: {{ section.settings.padding_top }}px !important;
    padding-bottom: {{ section.settings.padding_bottom }}px !important;
  }

  @media screen and (max-width: 768px) {
    .atlas-isolation-wrapper {{ section_id_selector }} .section-container-{{ section_id_variable }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
    }
  }

  /* Heading Styles */
  .atlas-isolation-wrapper {{ section_id_selector }} #heading-{{ section_id_variable }} {
    font-size: {% if global_heading_size %}var(--atlas-font-heading-size)!important{% else %}{{ section.settings.heading_size }}px!important{% endif %};
    line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-size) + 8px)!important{% else %}{{ section.settings.heading_size | plus: 8 }}px!important{% endif %};
    color: {% if global_color %}rgb(var(--atlas-color-base-heading)){% else %}{{ section.settings.heading_color }}{% endif %};
    --atlas-color-highlighted-color: {{ section.settings.bolded_heading_color }};
  }

  @media (max-width: 768px) {
    .atlas-isolation-wrapper {{ section_id_selector }} #heading-{{ section_id_variable }} {
      font-size: {% if global_heading_size %}var(--atlas-font-heading-mob-size) !important{% else %}{{ section.settings.heading_mob_size }}px!important{% endif %};
      line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-mob-size) + 8px) !important{% else %}{{ section.settings.heading_mob_size | plus: 8 }}px!important{% endif %};
    }
  }

  /* Body Text Styles */
  .atlas-isolation-wrapper {{ section_id_selector }} #section-body-text-{{ section_id_variable }},
  .atlas-isolation-wrapper #section-body-text-{{ section_id_variable }} p {
    font-size: {% if global_body_size %}var(--atlas-global-body-text-font-size){% else %}{{ section.settings.body_size }}px{% endif %} !important;
    line-height: {% if global_body_size %}calc(var(--atlas-global-body-text-font-size) + 8px){% else %}{{ section.settings.body_size | plus: 8 }}px{% endif %} !important;
    color: {% if global_color %}rgb(var(--atlas-color-base-text)){% else %}{{ section.settings.body_color }}{% endif %} !important;
  }

  .atlas-isolation-wrapper {{ section_id_selector }} #section-body-text-{{ section_id_variable }} strong {
    color: {{ section.settings.bolded_body_color }};
  }

  @media (max-width: 768px) {
    .atlas-isolation-wrapper {{ section_id_selector }} #section-body-text-{{ section_id_variable }} p,
    .atlas-isolation-wrapper {{ section_id_selector }} #section-body-text-{{ section_id_variable }} {
      font-size: {% if global_body_size %}var(--atlas-global-body-text-font-size)!important{% else %}{{ section.settings.body_size }}px !important{% endif %};
    }
  }
</style>

<style>
  .atlas-isolation-wrapper {{ section_id_selector }} .image-comparison-slider__wrapper {
    display: flex;

    width: 100%;
    background: {{ section.settings.card_background_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding_top}}px {{ section.settings.card_padding_right}}px {{ section.settings.card_padding_bottom}}px {{ section.settings.card_padding_left}}px;
  }
  /* Layout Styles */
  .atlas-isolation-wrapper {{ section_id_selector }} #leftSideContainer-{{ section_id_variable }} {
    text-align: center;
    padding-inline: max(12px, {{  section.settings.card_padding_left }}px) ;
    display: flex;
    flex-direction: column;
    {% if section.settings.desktop_content_alignment == 'left' %}
      align-items: flex-start;
    {% elsif section.settings.desktop_content_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: center;
    {% endif %}
  }
  .atlas-isolation-wrapper {{ section_id_selector }} #leftSideContainer-{{ section_id_variable }} > * {
    max-width: 462px;
  }

  .atlas-isolation-wrapper {{ section_id_selector }} #rightSideContainer-{{ section_id_variable }} {
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    height: {{ section.settings.image_height }}px;
  }
  @media (max-width: 768px) {
    .atlas-isolation-wrapper {{ section_id_selector }} #rightSideContainer-{{ section_id_variable }} {
      height: {{ section.settings.image_height_mobile }}px;
      width: 100%;
    }
  }
  {% if section.settings.enable_grayscale_before_image %}
    .atlas-isolation-wrapper {{ section_id_selector }} .image--before img {
      filter: grayscale(100%);
    }
  {% endif %}
  .atlas-isolation-wrapper {{ section_id_selector }} .label {
    position: absolute;
    z-index: 5;
    top: 17px;
    width: fit-content;
    border-top-right-radius: {{ section.settings.labels_border_radius }}px;
    border-bottom-right-radius: {{ section.settings.labels_border_radius }}px;
    background: {{ section.settings.labels_background_color }};
    padding: 3px 6px 5px 8px;
    font-size: {{ section.settings.labels_font_size }}px;
    font-weight: 500;
    line-height: {{ section.settings.labels_font_size }}px;
    color: {{ section.settings.labels_text_color }};
  }
  .atlas-isolation-wrapper {{ section_id_selector }} .divider__icon {
    width: {{ section.settings.divider_icon_size }}px;
    height: {{ section.settings.divider_icon_size }}px;
  }
  .atlas-isolation-wrapper {{ section_id_selector }} .label--before {
    left: 0;
  }

  .atlas-isolation-wrapper {{ section_id_selector }} .divider {
    background: {{ section.settings.line_color }} !important;
    width: {{ section.settings.line_width }}px;
  }



  .atlas-isolation-wrapper {{ section_id_selector }} .image-comparison-slider__wrapper {
    display: flex;
    align-items: center;
    {% if section.settings.layout_desktop == 'slider_second' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  @media screen and (max-width: 768px) {
    .atlas-isolation-wrapper {{ section_id_selector }} .image-comparison-slider__wrapper {
      {% if section.settings.layout_mobile == 'slider_second_mobile' %}
        flex-direction: column;
      {% else %}
        flex-direction: column-reverse;
      {% endif %}
      gap: 36px;
      padding: {{ section.settings.card_padding_top_mobile}}px {{ section.settings.card_padding_right_mobile}}px {{ section.settings.card_padding_bottom_mobile}}px {{ section.settings.card_padding_left_mobile}}px;
    }
    .atlas-isolation-wrapper {{ section_id_selector }} #leftSideContainer-{{ section_id_variable }} > * {
      max-width: 100%;
    }
    .atlas-isolation-wrapper {{ section_id_selector }} #leftSideContainer-{{ section_id_variable }} {
      padding-inline: max(12px, {{  section.settings.card_padding_left_mobile }}px) ;
    }
  }
</style>

<div
  id="image-slider-section-{{ section.id }}"
  class="section__image_comparison_slider"
  style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
>
  <div class="page-width section-container-{{ section_id_variable }}">
    <div class="image-comparison-slider__wrapper">
      <div
        id="leftSideContainer-{{ section_id_variable }}"
        style="display:flex;"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <style>
                {{ section_id_selector }} #heading-section-{{ block.id }} {
                  color: {% if global_color %}rgb(var(--atlas-color-base-heading)){% else %}{{ block.settings.color }}{% endif %};
                  font-size: {% if global_heading_size %}var(--atlas-font-heading-size) !important{% else %}{{ block.settings.size }}px !important{% endif %};
                  line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-size) + 8px) !important{% else %}{{ block.settings.size | plus: 8 }}px{% endif %};
                  margin: 0;
                  padding-top: {{ block.settings.padding_top_desktop }}px;
                  padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
                  text-align: {{ section.settings.desktop_content_alignment }};
                  {% if section.settings.desktop_content_alignment == 'left' %}
                    align-self: flex-start;
                  {% elsif section.settings.desktop_content_alignment == 'right' %}
                    align-self: flex-end;
                  {% else %}
                    align-self: center;
                  {% endif %}
                }
                @media (max-width: 768px) {
                  {{ section_id_selector }} #heading-section-{{ block.id }} {
                    padding-top: {{ block.settings.padding_top_mobile }}px;
                    padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
                    font-size: {% if global_heading_size %}var(--atlas-font-heading-mob-size) !important{% else %}{{ block.settings.mobile_font_size }}px !important{% endif %};
                    line-height: {% if global_heading_size %}calc(var(--atlas-font-heading-mob-size) + 6px) !important{% else %}{{ block.settings.mobile_font_size | plus: 6 }}px{% endif %};
                    text-align: {{ section.settings.mobile_content_alignment }};
                    {% if section.settings.mobile_content_alignment == 'left' %}
                      align-self: flex-start;
                    {% elsif section.settings.mobile_content_alignment == 'right' %}
                      align-self: flex-end;
                    {% else %}
                      align-self: center;
                    {% endif %}
                  }
                }

                {{ section_id_selector }} #heading-section-{{ block.id }} strong {
                  {%- if block.settings.heading_use_gradient -%}
                    background: {% if block.settings.heading_gradient_color != blank %}{{ block.settings.heading_gradient_color }}{% else %}var(--atlas-gradient-base-background-1){% endif %};
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                  {%- endif -%}
                }
              </style>

              <h2 id="heading-section-{{ block.id }}" class="title banner__heading" {{ block.shopify_attributes }}>
                <span style="--atlas-color-highlighted-color: {{ block.settings.highlighted_color }};">
                  {{- block.settings.heading -}}
                </span>
              </h2>

            {%- when 'text' -%}
              <style>
                #text-section-{{ block.id }} {
                  margin: 0;
                  padding-top: {{ block.settings.padding_top_desktop }}px;
                  padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
                  text-align: {{ section.settings.desktop_content_alignment }};
                  font-size: {{ block.settings.size }}px;
                  line-height: {{ block.settings.size | plus: 8 }}px;
                  color: {% if global_color %}rgb(var(--atlas-color-base-text)){% else %}{{ block.settings.color }}{% endif %};
                  {% if section.settings.desktop_content_alignment == 'left' %}
                    align-self: flex-start;
                  {% elsif section.settings.desktop_content_alignment == 'right' %}
                    align-self: flex-end;
                  {% else %}
                    align-self: center;
                  {% endif %}
                }
                #text-section-{{ block.id }} strong {
                  {% if block.settings.text_use_gradient %}
                    background: {% if block.settings.text_gradient_color != blank %}{{ block.settings.text_gradient_color }}{% else %}var(--atlas-color-highlighted-color){% endif %};
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                  {% else %}
                    color: {{ block.settings.highlighted_color }};
                  {% endif %}
                }
                @media (max-width: 750px) {
                  #text-section-{{ block.id }} {
                    padding-top: {{ block.settings.padding_top_mobile }}px;
                    padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
                    text-align: {{ section.settings.mobile_content_alignment }};
                    font-size: {{ block.settings.size_mobile }}px;
                    line-height: {{ block.settings.size_mobile | plus: 6 }}px;
                    {% if section.settings.mobile_content_alignment == 'left' %}
                      align-self: flex-start;
                    {% elsif section.settings.mobile_content_alignment == 'right' %}
                      align-self: flex-end;
                    {% else %}
                      align-self: center;
                    {% endif %}
                  }
                }
              </style>
              <div
                id="text-section-{{ block.id }}"
                class="body image-with-text__text rte sw-base-text-color body"
                {{ block.shopify_attributes }}
              >
                <div>{{ block.settings.text }}</div>
              </div>

            {%- when 'buttons' -%}
              <style>
                #buttons-section-{{ block.id }} {
                  padding-top: {{ block.settings.padding_top_desktop }}px;
                  padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
                  margin: 0;
                  display: flex;
                  text-align: {{ section.settings.desktop_content_alignment }};
                  {% if section.settings.desktop_content_alignment == 'left' %}
                   justify-content: flex-start;
                  {% elsif section.settings.desktop_content_alignment == 'right' %}
                   justify-content: flex-end;
                  {% else %}
                   justify-content: center;
                  {% endif %}
                  width: 100%;
                  max-width: 100%;
                }
                #buttons-section-{{ block.id }} #button-1-{{ block.id }} {
                  font-size: {{ block.settings.button_label_1_size }}px;
                  line-height: {{ block.settings.button_label_1_size | plus: 8 }}px;
                  color: {{ block.settings.button_1_text_color }};
                  background-color: {{ block.settings.button_1_background_color }};
                  border-radius: {{ block.settings.button_1_border_radius }}px !important;
                  padding: {{ block.settings.button_padding_vertical }}px 12px;
                  max-width: {{ block.settings.button_width_increase_desktop }}%;
                  min-width: fit-content;
                  width: 100%;
                  flex-shrink: 0;
                }
                #buttons-section-{{ block.id }} #button-1-{{ block.id }} .button-text {
                  font-size: {{ block.settings.button_label_1_size }}px;
                  line-height: {{ block.settings.button_label_1_size | plus: 8 }}px;
                  color: {{ block.settings.button_1_text_color }};
                }
                @media (max-width: 750px) {
                  #buttons-section-{{ block.id }} {
                    padding-top: {{ block.settings.padding_top_mobile }}px;
                    padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
                    text-align: {{ section.settings.mobile_content_alignment }};
                    {% if section.settings.mobile_content_alignment == 'left' %}
                      justify-content: flex-start;
                    {% elsif section.settings.mobile_content_alignment == 'right' %}
                      justify-content: flex-end;
                    {% else %}
                      justify-content: center;
                    {% endif %}
                  }
                  #buttons-section-{{ block.id }} #button-1-{{ block.id }} {
                    font-size: {{ block.settings.button_label_1_size_mobile }}px;
                    line-height: {{ block.settings.button_label_1_size_mobile | plus: 6 }}px;
                    padding: {{ block.settings.button_padding_vertical }}px 12px;
                    max-width: {{ block.settings.button_width_increase_mobile }}%;
                  }
                  #buttons-section-{{ block.id }} #button-1-{{ block.id }} .button-text {
                    font-size: {{ block.settings.button_label_1_size_mobile }}px;
                    line-height: {{ block.settings.button_label_1_size_mobile | plus: 6 }}px;
                  }
                }
              </style>
              <div
                id="buttons-section-{{ block.id }}"
                class="banner__buttons banner__buttons-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.button_label_1 != blank -%}
                  <a
                    id="button-1-{{ block.id }}"
                    {% if block.settings.button_link_1 == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link_1 }}"
                    {% endif %}
                    class="button"
                  >
                    <span class="button-text">{{- block.settings.button_label_1 | escape -}}</span>
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      <div
        id="rightSideContainer-{{ section_id_variable }}"
        class="half flex-align-center"
      >
        <div class="image-compare" data-section-id="{{ section_id_variable }}">
          {% unless section.settings.before_label == blank %}
            <div class="label label--before">
              {{ section.settings.before_label }}
            </div>
          {% endunless %}

          <div class="image-wrapper">
            <div
              class="image image--before"
              style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
            >
              {%- if section.settings.before_image != blank -%}
                {{ section.settings.before_image | image_url: width: 1000 | image_tag: loading: 'lazy', width: 450 }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder' }}
              {%- endif -%}
            </div>

            <div
              class="image image--after"
              style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
            >
              {%- if section.settings.after_image != blank -%}
                {{ section.settings.after_image | image_url: width: 1000 | image_tag: loading: 'lazy', width: 450 }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder' }}
              {%- endif -%}
            </div>

            <div class="divider">
              <svg
                class="divider__icon"
                width="40"
                height="40"
                viewBox="0 0 40 40"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <rect width="40" height="40" rx="13" fill="{{ section.settings.line_color }}"/>
                <rect x="26" y="13.8608" width="12.6282" height="1.84803" transform="rotate(90 26 13.8608)" fill="{{ section.settings.divider_icon_color }}"/>
                <rect x="21.1191" y="13.8608" width="12.6282" height="1.84803" transform="rotate(90 21.1191 13.8608)" fill="{{ section.settings.divider_icon_color }}"/>
                <rect x="16.2383" y="13.8608" width="12.6282" height="1.84803" transform="rotate(90 16.2383 13.8608)" fill="{{ section.settings.divider_icon_color }}"/>
              </svg>
            </div>

            <input
              type="range"
              class="slider-control"
              min="0"
              max="100"
              value="{{ section.settings.default_slider_position | default: 50 }}"
              aria-label="Image comparison slider"
            >
          </div>

          {% unless section.settings.after_label == blank %}
            <div class="label label--after">
              {{ section.settings.after_label }}
            </div>
          {% endunless %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  class ImageCompare{{ section.id | replace: '-', '' }} {
    constructor(container) {
      this.container = container;
      this.slider = container.querySelector('.slider-control');
      this.beforeImage = container.querySelector('.image--before');
      this.afterImage = container.querySelector('.image--after');
      this.divider = container.querySelector('.divider');
      this.beforeLabel = container.querySelector('.label--before');
      this.afterLabel = container.querySelector('.label--after');

      this.bindEvents();
      this.updateImages(this.slider.value);
    }

    bindEvents() {
      this.slider.addEventListener('input', () => this.updateImages(this.slider.value));
    }

    updateImages(value) {
      this.beforeImage.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      this.afterImage.style.clipPath = `inset(0 0 0 ${value}%)`;
      this.divider.style.left = `${value}%`;
      this.afterLabel.style.left = `calc(${value}% + {{ section.settings.line_width | divided_by: 2 }}px)`;
      if (value >= 85) {
        this.afterLabel.style.display = 'none';
        this.beforeLabel.style.display = 'block';
      } else if (value <= 15) {
        this.beforeLabel.style.display = 'none';
        this.afterLabel.style.display = 'block';
      } else {
        this.beforeLabel.style.display = 'block';
        this.afterLabel.style.display = 'block';
      }
    }
  }

  document.querySelectorAll('.image-compare').forEach((container) => {
    new ImageCompare{{ section.id | replace: '-', '' }}(container);
  });
  
  if (Shopify.designMode) {
    const sectionId = "{{ section_id_variable }}";
    const reloadImageCompare = () => {
      document.querySelectorAll('.image-compare').forEach((container) => {
        new ImageCompare{{ section.id | replace: '-', '' }}(container);
      });
    };

    document.addEventListener('shopify:section:unload', (event) => {
      if (event.detail.sectionId === sectionId) reloadImageCompare();
    });

    document.addEventListener('shopify:section:load', (event) => {
      if (event.detail.sectionId === sectionId) reloadImageCompare();
    });
  }
</script>

{% schema %}
{
  "name": "Before and after",
  "class": "atlas-isolation-wrapper atlas-gradient section animation_section",
  "settings": [
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Desktop image height",
      "min": 300,
