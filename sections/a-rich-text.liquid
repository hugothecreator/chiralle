{%- comment -%} CSS Imports {%- endcomment -%}
<style>
  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text {
    z-index: 1;
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__wrapper {
    display: flex;
    justify-content: center;
    /* width: calc(100% - 4rem / var(--atlas-font-body-scale)); */
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text:not(.rich-text--full-width) .rich-text__wrapper {
    margin: auto;
    /* width: calc(100% - 8rem / var(--atlas-font-body-scale)); */
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks {
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__wrapper {
      width: 100%;
    }

    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__wrapper--left {
      justify-content: flex-start;
    }

    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__wrapper--right {
      justify-content: flex-end;
    }
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks * {
    overflow-wrap: break-word;
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks > * {
    margin-top: 0;
    margin-bottom: 0;
  }


  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks > * + a {
    margin-top: 3rem;
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__buttons {
    display: inline-flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    width: 100%;
    max-width: 45rem;
    margin-bottom: 10px;
    word-break: break-word;
  }

  {% comment %} .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__buttons--multiple > * {
    flex-grow: 1;
    min-width: 22rem;
  } {% endcomment %}

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__buttons + .rich-text__buttons {
    margin-top: 1rem;
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks.left .rich-text__buttons {
    justify-content: flex-start;
  }

  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .rich-text__blocks.right .rich-text__buttons {
    justify-content: flex-end;
  }
</style>

{%- comment -%} Global Settings {%- endcomment -%}
{%- liquid
  assign global_heading_size = settings.enable_global_heading_font_size
  assign global_body_size = settings.enable_global_body_font_size
  assign global_color = settings.enable_global_color
-%}

{%- comment -%} Section Styles {%- endcomment -%}
{%- style -%}
  {%- if request.visual_preview_mode -%}
    {% comment %} don't want fade-in animation in preview mode because it messes up preview {% endcomment %}
    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .animation_section,
    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .animation_section * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto !important;
    }
  {%- endif -%}
  .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 750px) {
    .atlas-isolation-wrapper #section-rich-text-{{ section.id }} .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
{%- endstyle -%}

{%- comment -%} Main Section {%- endcomment -%}

<div id="section-rich-text-{{ section.id }}">
  <div
    class="rich-main"
    style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}"
  >
    <div class="rich-text page-width content-container rich-text--full-width content-container--full-width section-{{ section.id }}-padding">
      <div class="rich-text__wrapper rich-text__wrapper--center">
        <div class="rich-text__blocks {{ section.settings.content_alignment }}">
          {%- comment -%} Heading Block {%- endcomment -%}
          {%- if section.settings.heading != blank -%}
            {%- style -%}
              .atlas-isolation-wrapper #section-heading-{{ section.id }} {
                font-size: {% if global_heading_size %}var(--atlas-font-heading-size)!important{% else %}{{ section.settings.heading_font_size }}px!important{% endif %};
                color: {% if global_color %}rgb(var(--atlas-color-base-heading)){% else %}{{ section.settings.heading_color }}{% endif %} !important;
                --atlas-color-highlighted-color: {{ section.settings.heading_highlighted_color }};
                display: flex;
                width: 100%;
                {% if section.settings.content_alignment == 'center' %}
                  justify-content: center;
                {% elsif section.settings.content_alignment == 'right' %}
                  justify-content: flex-end;
                {% else %}
                  justify-content: flex-start;
                {% endif %}
              }
              .atlas-isolation-wrapper #section-heading-{{ section.id }} p {
                max-width: 610px;
              }
              @media (max-width: 768px) {
                .atlas-isolation-wrapper #section-heading-{{ section.id }} {
                  font-size: {% if global_heading_size %}var(--atlas-font-heading-mob-size) !important{% else %}{{ section.settings.mobile_heading_font_size }}px!important{% endif %};
                }
              }

              .atlas-isolation-wrapper #section-heading-{{ section.id }} strong {
                {%- if section.settings.heading_use_gradient -%}
                  background: {% if section.settings.heading_gradient_color != blank %}{{ section.settings.heading_gradient_color }}{% else %}var(--atlas-gradient-base-background-1){% endif %};
                  -webkit-background-clip: text;
                  background-clip: text;
                  color: transparent;
                {%- endif -%}
              }
            {%- endstyle -%}

            <h2
              id="section-heading-{{ section.id }}"
              class="rich-text__heading title"
              style="margin-top: 0;"
              {{ section.shopify_attributes }}
            >
              <p style="margin:0;">
                {{ section.settings.heading | replace: 'p>', 'span>' }}
              </p>
            </h2>
          {%- endif -%}

          {%- comment -%} Text Block {%- endcomment -%}
          {%- if section.settings.text != blank -%}
            {%- style -%}
              .atlas-isolation-wrapper #rich-text__text-{{ section.id }} p,
              .atlas-isolation-wrapper #rich-text__text-{{ section.id }} {
                font-size: {% if global_body_size %}var(--atlas-global-body-text-font-size)!important{% else %}{{ section.settings.body_font_size }}px!important{% endif %};
                line-height: 1.4em;
                color: {% if global_color %}rgb(var(--atlas-color-base-text)){% else %}{{ section.settings.body_color }}{% endif %};
                --atlas-color-highlighted-color: {{ section.settings.body_highlighted_color }};
              }
              .atlas-isolation-wrapper #rich-text__text-{{ section.id }} {
                max-width: {{ section.settings.text_max_width_percentage }}%;
                width: 100%;
              }
              @media (max-width: 768px) {
                .atlas-isolation-wrapper #rich-text__text-{{ section.id }} {
                  max-width: {{ section.settings.text_max_width_percentage_mobile }}%;
                }
              }
            {%- endstyle -%}

            <div
              id="rich-text__text-{{ section.id }}"
              class="rich-text__text sw-base-text-color image-with-text__text rte body"
              {% if section.settings.content_alignment == 'center' %}
                style="margin: 0 auto; margin-top: 10px;"
              {% elsif section.settings.content_alignment == 'right' %}
                style="margin-left: auto; margin-top: 10px;"
              {% else %}
                style="margin-right: auto; margin-top: 10px;"
              {% endif %}
              {{ section.shopify_attributes }}
            >
              {{ section.settings.text }}
            </div>
          {%- endif -%}

          {%- comment -%} Buttons Block {%- endcomment -%}
          {%- if section.settings.button_label != blank or section.settings.button_label_2 != blank -%}
            <div
              class="rich-text__buttons rich-text__buttons-{{ section.id }} {% if section.settings.button_label != blank and section.settings.button_label_2 != blank %}rich-text__buttons--multiple{% endif %}"
              {{ section.shopify_attributes }}
            >
              {%- style -%}
                .atlas-isolation-wrapper .rich-text__buttons-{{ section.id }} .button:after {
                  box-shadow: 0 0 0 calc(var(--atlas-buttons-border-width) + var(--atlas-border-offset)) rgba(255, 255, 255, calc(1 - 1.0)), 0 0 0 var(--atlas-buttons-border-width) var(--atlas-color-base-accent-1);
                }
              {%- endstyle -%}

              {%- if section.settings.button_label != blank -%}
                {% style %}
                  .atlas-isolation-wrapper .rich-text__buttons-{{ section.id }} .button {
                    padding: {{ section.settings.button_padding_vertical }}px 12px;
                    font-size: {{ section.settings.button_font_size }}px !important;
                    line-height: {{ section.settings.button_font_size | plus: 8 }}px !important;
                    color: {{ section.settings.button_color }};
                    background-color: {{ section.settings.button_bg_color }};
                    border-radius: {{ section.settings.button_border_radius }}px !important;
                    max-width: {{ section.settings.button_width_increase_desktop }}%;
                    min-width: fit-content;
                    width: 100%;
                    flex-shrink: 0;
                    margin-top: 25px;
                  }
                  .atlas-isolation-wrapper .rich-text__buttons-{{ section.id }} .button:not([aria-disabled="true"]):hover {
                    padding-right: 12px;
                  }
                  @media (max-width: 768px) {
                    .atlas-isolation-wrapper .rich-text__buttons-{{ section.id }} .button {
                      padding: {{ section.settings.button_padding_vertical_mobile }}px 12px;
                      font-size: {{ section.settings.button_font_size_mobile }}px !important;
                      line-height: {{ section.settings.button_font_size_mobile | plus: 8 }}px !important;
                      max-width: {{ section.settings.button_width_increase_mobile }}%;
                    }
                    .atlas-isolation-wrapper .rich-text__buttons-{{ section.id }} .button:not([aria-disabled="true"]):hover {
                      padding-right: 12px;
                    }
                  }
                {% endstyle %}
                <a
                  {% if section.settings.button_link == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ section.settings.button_link }}"
                  {% endif %}
                  class="button button--primary"
                >
                  <span class="button-text">{{ section.settings.button_label | escape }}</span>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

          {% comment %} List cards blocks{% endcomment %}
          {% content_for 'block', type: '_a-rich-text-list-cards', id: 'list-cards' %}
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Section Schema {%- endcomment -%}
{% schema %}
{
  "name": "Rich text",
  "tag": "section",
  "class": "atlas-isolation-wrapper atlas-gradient section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Talk about your brand",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
      "label": "Body"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Content alignment"
    },
    {
      "type": "range",
      "id": "text_max_width_percentage",
      "label": "Desktop text max width percentage",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 80
    },
    {
      "type": "range",
      "id": "text_max_width_percentage_mobile",
      "label": "Mobile text max width percentage",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Desktop heading size",
      "min": 20,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_heading_font_size",
      "label": "Mobile heading size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_highlighted_color",
      "label": "Bolded heading color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "heading_use_gradient",
      "label": "Use gradient for heading",
      "info": "Any text formatted as bold within the heading will be converted to a gradient.",
      "default": false
    },
    {
      "type": "color_background",
      "id": "heading_gradient_color",
      "label": "Heading gradient color",
      "visible_if": "{{ section.settings.heading_use_gradient }}",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#302F2F"
    },
    {
      "type": "color",
      "id": "body_highlighted_color",
      "label": "Bolded body color",
      "default": "#302F2F"
    },
    {
      "type": "header",
      "content": "Section styling"
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color_background",
      "id": "section_background_gradient",
      "label": "Section background gradient",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)",
      "visible_if": "{{ section.settings.use_gradient_background }}"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_gradient_background == false }}"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "inline_richtext",
      "id": "button_label",
      "default": "Button label",
      "label": "Button label",
      "info": "Note: Leave blank to hide"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Desktop button font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "label": "Mobile button font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Button vertical padding",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_width_increase_desktop",
      "label": "Desktop button width increase",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_padding_vertical_mobile",
      "label": "Mobile button vertical padding",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_width_increase_mobile",
      "label": "Mobile button width increase",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 80
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ]
}
{% endschema %}
