{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'a-component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {%- if request.visual_preview_mode -%}
    {% comment %} don't want fade-in animation in preview mode because it messes up preview {% endcomment %}
    .animation_section,
    .animation_section * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      will-change: auto !important;
    }
  {%- endif -%}
  #shopify-section-{{ section.id }} .collection-hero {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .collection-hero__image-container {
    width: {{section.settings.image_width}}px;
    height: {{section.settings.image_height}}px;
    object-fit: cover;
    border-radius: {{section.settings.image_border_radius}}px;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .collection-hero__text-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: {{ section.settings.gap_between_title_and_description }}px;
    max-width: 527px;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .collection-hero__inner {
    gap: 28px;
  }
  @media screen and (max-width: 750px) {
    #shopify-section-{{ section.id }} .collection-hero__inner {
      max-width: 100%;
    }
  }
  #shopify-section-{{ section.id }} .collection-hero__title {
    font-size: {{ section.settings.title_size_desktop }}px !important;
    line-height: {{ section.settings.title_size_desktop | plus: 12 }}px !important;
    color: {{ section.settings.title_color }};
    font-weight: 500 !important;
    margin: 0 !important;
  }
  #shopify-section-{{ section.id }} .collection-hero__description, #shopify-section-{{ section.id }} .collection-hero__description p {
    font-size: {{ section.settings.description_size_desktop }}px !important;
    line-height: {{ section.settings.description_size_desktop | plus: 12 }}px !important;
    color: {{ section.settings.description_color }};
    font-weight: 300;
  }
  @media screen and (max-width: 750px) {
    #shopify-section-{{ section.id }} .collection-hero__title {
      font-size: {{ section.settings.title_size_mobile }}px !important;
      line-height: {{ section.settings.title_size_mobile | plus: 8 }}px !important;
    }
  }
  @media screen and (max-width: 750px) {
    #shopify-section-{{ section.id }} .collection-hero__description, #shopify-section-{{ section.id }} .collection-hero__description p {
      font-size: {{ section.settings.description_size_mobile }}px !important;
      line-height: {{ section.settings.description_size_mobile | plus: 8 }}px !important;
    }
  }
{%- endstyle -%}

<div class="collection-hero{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %} gradient" style="{% if section.settings.use_gradient_background %}background: {{ section.settings.section_background_gradient }};{% else %}background-color: {{ section.settings.section_background_color }};{% endif %}">
  <div class="collection-hero__inner page-width">
    
    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media gradient">
        <img
          srcset="
            {%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
            {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ collection.image | image_url }} {{ collection.image.width }}w
          "
          src="{{ collection.image | image_url: width: 750 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
          alt=""
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
        >
      </div>
    {%- endif -%}
    <div class="collection-hero__text-wrapper">
      <h1 class="collection-hero__title title">
        <span class="visually-hidden">Collection: </span>
        {{- collection.title | escape -}}
      </h1>

      {%- if section.settings.show_collection_description -%}
        <div class="collection-hero__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Collection banner",
  "class": "section animation_section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Add a description or image by editing your collection. [Learn more](https://help.shopify.com/manual/products/collections/collection-layout)"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Show collection description"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "Show collection image",
      "info": "For best results, use an image with a 16:9 aspect ratio. [Learn more](https://help.shopify.com/manual/shopify-admin/productivity-tools/image-editor#understanding-image-aspect-ratio)"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 10,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Desktop title size",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 10,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Mobile title size",
      "default": 20
    },
    {
      "type": "range",
      "id": "description_size_desktop",
      "min": 10,
      "max": 42,
      "step": 1,
      "unit": "px",
      "label": "Desktop description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "min": 10,
      "max": 42,
      "step": 1,
      "unit": "px",
      "label": "Mobile description size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "gap_between_title_and_description",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Gap between title and description",
      "default": 7
    },
    {
      "type": "checkbox",
      "id": "use_gradient_background",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color_background",
      "id": "section_background_gradient",
      "label": "Section background gradient",
      "default": "linear-gradient(180deg, rgba(251, 51, 166, 1), rgba(127, 72, 176, 1) 50%, rgba(48, 145, 211, 1) 100%)",
      "visible_if": "{{ section.settings.use_gradient_background }}"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
      "default": "#ffffff",
      "visible_if": "{{ section.settings.use_gradient_background == false }}"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 80,
      "max": 240,
      "step": 2,
      "unit": "px",
      "label": "Desktop image width",
      "default": 98
    },
    {
      "type": "range",
      "id": "image_height",
      "min": 80,
      "max": 240,
      "step": 2,
      "unit": "px",
      "label": "Desktop image height",
      "default": 90
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Image border radius",
      "default": 6
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
   
  ]
}
{% endschema %}
